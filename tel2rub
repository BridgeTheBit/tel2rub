#!/bin/bash

SERVICE="tel2rub"
REPO_DIR="/opt/tel2rub"
VERSION=$(cat $REPO_DIR/VERSION 2>/dev/null || echo "unknown")

YELLOW="\e[33m"
GREEN="\e[32m"
RED="\e[31m"
NC="\e[0m"

get_queue_count() {
    if [ -f "$REPO_DIR/queue/tasks.jsonl" ]; then
        wc -l < "$REPO_DIR/queue/tasks.jsonl"
    else
        echo 0
    fi
}

folder_size() {
    du -sh "$1" 2>/dev/null | cut -f1
}

while true
do
clear
echo -e "${GREEN}=========== Tel2Rub Manager ===========${NC}"
echo -e "Version: ${YELLOW}$VERSION${NC}"
echo ""
echo -e "Queue files:  ${YELLOW}$(get_queue_count) files${NC}"
echo -e "Downloads:    ${YELLOW}$(folder_size $REPO_DIR/downloads)${NC}"
echo -e "Logs:         ${YELLOW}$(folder_size $REPO_DIR/logs)${NC}"
echo ""
echo "1) Status"
echo "2) Live Logs"
echo "3) Restart Service"
echo "4) Stop Service"
echo "5) Start Service"
echo "6) Update (Auto Backup & Rollback)"
echo "7) Uninstall Completely"
echo "8) Exit"
echo ""
read -p "Select: " choice

case $choice in

1)
systemctl status $SERVICE --no-pager
read -p "Press Enter..."
;;

2)
tail -f $REPO_DIR/logs/app.log
;;

3)
systemctl restart $SERVICE
echo -e "${GREEN}Service restarted.${NC}"
sleep 1
;;

4)
systemctl stop $SERVICE
echo -e "${RED}Service stopped.${NC}"
sleep 1
;;

5)
systemctl start $SERVICE
echo -e "${GREEN}Service started.${NC}"
sleep 1
;;

6)
echo -e "${YELLOW}Running official updater...${NC}"
bash <(curl -s https://raw.githubusercontent.com/BridgeTheBit/tel2rub/main/install.sh)
echo -e "${GREEN}Update completed.${NC}"
sleep 2
;;

7)
echo -e "${RED}Are you sure you want to uninstall Tel2Rub? (y/n)${NC}"
read -p "> " confirm

if [[ "$confirm" == "y" ]]; then
    systemctl stop $SERVICE
    systemctl disable $SERVICE
    rm -f /etc/systemd/system/$SERVICE.service
    systemctl daemon-reload

    rm -f /usr/local/bin/tel2rub
    rm -rf $REPO_DIR

    echo -e "${GREEN}Tel2Rub completely removed.${NC}"
    exit
else
    echo -e "${YELLOW}Canceled.${NC}"
    sleep 1
fi
;;

8)
exit
;;

*)
echo -e "${RED}Invalid option.${NC}"
sleep 1
;;

esac
done
